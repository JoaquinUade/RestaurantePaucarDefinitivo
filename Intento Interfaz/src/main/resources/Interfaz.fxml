<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="Controlador">

    <!-- Título -->
    <Label text="Bienvenida a mi aplicación"/>

    <!-- Campo de texto -->
    <TextField fx:id="campoNombre"
               promptText="Escribí tu nombre"/>

    <!-- Botón -->
    <Button text="Saludar"
            onAction="#saludar"/>

    <!-- Resultado -->
    <Label fx:id="textoResultado"/>

</VBox>